<?xml version="1.0"?>
<package >
  <metadata>
    <id>Cronos</id>
    <version>%version%</version>
    <title>Cronos</title>
    <authors>Andrey Dorokhov, Sergey Odinokov</authors>
    <owners>HangfireIO</owners>
    <projectUrl>https://github.com/HangfireIO/Cronos</projectUrl>
    <repository type="git" url="https://github.com/HangfireIO/Cronos.git" commit="%commit%" />
    <license type="expression">MIT</license>
    <description>A fully-featured .NET library for parsing cron expressions and calculating next occurrences that was designed with time zones in mind and correctly handles daylight saving time transitions.</description>
    <copyright>Copyright © 2016–2026 Hangfire OÜ.</copyright>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <tags>Cronos Cron Recurring</tags>
    <releaseNotes><![CDATA[https://github.com/HangfireIO/Cronos/releases

0.13.0
• Added – Add support for retrieving previous occurrences in Cron expressions (by @israellot).

0.12.0
• Added – Support schedule jitter with the `H` character (by @epicoxymoron).
• Changed – Use unsigned types instead of signed ones internally (in collaboration with @joesdu).
• Project – Replace `netcoreapp3.1` platform with `net8.0` in tests.

]]></releaseNotes>
    <dependencies>
      <group targetFramework="net40">
      </group>
      <group targetFramework="net45">
      </group>
      <group targetFramework="netstandard1.0">
        <dependency id="NETStandard.Library" version="1.6.1" />
      </group>
      <group targetFramework="netstandard2.0">
      </group>
      <group targetFramework="net6.0">
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="net40\Cronos.dll" target="lib\net40" />
    <file src="net40\Cronos.xml" target="lib\net40" />

    <file src="net45\Cronos.dll" target="lib\net45" />
    <file src="net45\Cronos.xml" target="lib\net45" />

    <file src="netstandard1.0\Cronos.dll" target="lib\netstandard1.0" />
    <file src="netstandard1.0\Cronos.xml" target="lib\netstandard1.0" />

    <file src="netstandard2.0\Cronos.dll" target="lib\netstandard2.0" />
    <file src="netstandard2.0\Cronos.xml" target="lib\netstandard2.0" />

    <file src="net6.0\Cronos.dll" target="lib\net6.0" />
    <file src="net6.0\Cronos.xml" target="lib\net6.0" />

    <file src="icon.png" />
    <file src="LICENSE" />
    <file src="README.md" />
  </files>
</package>